{
  "name": "groww-assignment-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome lint .",
    "format": "biome format .",
    "prepare": "husky install",
    "pages:build": "npx @cloudflare/next-on-pages",
    "pages:deploy": "npm run pages:build && wrangler pages deploy .vercel/output",
    "pages:dev": "wrangler pages dev .vercel/output --compatibility-flag=nodejs_compat",
    "pages:watch": "npx @cloudflare/next-on-pages --watch"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.5",
    "@ant-design/nextjs-registry": "^1.3.0",
    "antd": "^6.4.5",
    "dayjs": "^1.11.21",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@cloudflare/next-on-pages": "^1.13.16",
    "@cloudflare/workers-types": "^4.20260623.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "husky": "^9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.103.0"
  }
}
